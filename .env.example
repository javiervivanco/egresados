# Frontend público y admin SPA leen las mismas variables.
# Para dev local: copiar a .env.local y dejar los valores de localhost.
# Para prod: usar los valores del proyecto Supabase remoto.

# === DEV LOCAL ===
# Las keys reales las imprime `make status`. Copialas acá tras levantar el stack.
# Las versiones nuevas de la CLI usan formato sb_publishable_* / sb_secret_* en
# lugar del histórico JWT anon/service_role.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_REEMPLAZAR_CON_make_status

# === Secret key (server-side, NUNCA en el cliente) ===
# SUPABASE_SECRET_KEY=sb_secret_REEMPLAZAR_CON_make_status
